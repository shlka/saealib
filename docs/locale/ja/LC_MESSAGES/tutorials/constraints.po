msgstr ""

#: ../../../tutorials/constraints.md
msgid "固定の許容誤差`eps_cv`で実行可能性を判定する（デフォルト）"
msgstr ""

#: ../../../tutorials/constraints.md
msgid "`EpsilonConstraintHandler`"
msgstr ""

#: ../../../tutorials/constraints.md
msgid "許容誤差を世代とともに0へ近づけ、徐々に実行可能領域へ解を追い込む"
msgstr ""

#: ../../../tutorials/constraints.md
msgid "`GradientRepairHandler`"
msgstr ""

#: ../../../tutorials/constraints.md
msgid "制約の勾配を使って実行不可能解を修復する"
msgstr ""

#: ../../../tutorials/constraints.md:95
msgid "`EpsilonConstraintHandler`には、世代番号を受け取り許容誤差を返す関数を渡します。"
msgstr ""

