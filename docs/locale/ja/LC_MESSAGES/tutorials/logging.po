#, python-brace-format
msgid ""
"{py:func}`saealib.logging_generation` / "
"{py:func}`saealib.logging_generation_hv`"
msgstr ""

#: ../../../tutorials/logging.md:115
#, python-brace-format
msgid ""
"{py:class}`saealib.CallbackManager` / "
"{py:class}`saealib.GenerationStartEvent`"
msgstr ""

